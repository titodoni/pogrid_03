# =============================================================
# POGrid Environment Variables
# Copy file ini ke .env.local untuk development
# Set semua variable ini di Vercel Dashboard > Settings > Environment Variables
# =============================================================

# ------ DATABASE (Neon PostgreSQL) ------
# Ambil dari Neon Dashboard > Connection Details

# Pooled connection — dipakai oleh app saat runtime (Next.js API routes)
# Format: postgresql://user:pass@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Direct connection — dipakai oleh prisma migrate & prisma db seed
# Format: postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL_UNPOOLED=

# ------ AUTH / SESSION ------
# String acak panjang minimal 32 karakter — generate: openssl rand -base64 32
SESSION_SECRET=

# ------ APP ------
NEXT_PUBLIC_APP_URL=http://localhost:3000
